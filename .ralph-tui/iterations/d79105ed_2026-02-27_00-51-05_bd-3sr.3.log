{"type":"tool_use","timestamp":1772179442774,"sessionID":"ses_361eb8b90ffeYmwBV3N68Ex01B","part":{"id":"prt_c9e2049f40012ihGGHht9JjCZY","sessionID":"ses_361eb8b90ffeYmwBV3N68Ex01B","messageID":"msg_c9e203db0001o9EVb7afIP7T4r","type":"tool","callID":"toolu_01ADp9ZeYcWXY2F6hMr22Pqv","tool":"read","state":{"status":"completed","input":{"filePath":"/Users/mat/dev/farsight/agent-framework/src/engine.ts"},"output":"<path>/Users/mat/dev/farsight/agent-framework/src/engine.ts</path>\n<type>file</type>\n<content>1: import { loadConfig } from \"./config.js\";\n2: import { startServer, connectToServer, createSession, runPrompt, type ServerHandle } from \"./opencode.js\";\n3: import { appendProgress } from \"./progress.js\";\n4: import type { LoopConfig, LoopResult, IterationResult, CompletionResult, PhaseFlags } from \"./types.js\";\n5: import { EngineEventEmitter, attachDefaultConsoleRenderer, type EngineEventListener } from \"./events.js\";\n6: import { startRunTracker } from \"./run-state.js\";\n7: import { withTimeout } from \"./timeout.js\";\n8: \n9: export interface PhaseIteration {\n10:   prompt: string;\n11:   model: { providerID: string; modelID: string };\n12:   sessionTitle: string;\n13:   iterationLabel: string;\n14:   beadId?: string;\n15:   systemPrompt?: string;\n16: }\n17: \n18: export interface PhaseCallbacks {\n19:   setup(config: LoopConfig, dryRun: boolean): Promise<{ maxIterations: number; description: string }>;\n20:   nextIteration(config: LoopConfig, iteration: number): Promise<PhaseIteration | null>;\n21:   handleResult(result: CompletionResult, iteration: number): Promise<boolean>;\n22: }\n23: \n24: export async function runPhaseLoop(\n25:   projectDir: string,\n26:   callbacks: PhaseCallbacks,\n27:   flags: PhaseFlags,\n28:   onEvent?: EngineEventListener,\n29: ): Promise<LoopResult> {\n30:   const emitter = new EngineEventEmitter();\n31:   const detachConsole = attachDefaultConsoleRenderer(emitter);\n32:   const detachExternal = onEvent ? emitter.on(onEvent) : null;\n33: \n34:   let server: ServerHandle | undefined;\n35: \n36:   const cleanup = () => {\n37:     if (server) {\n38:       server.close();\n39:     }\n40:     detachConsole();\n41:     if (detachExternal) detachExternal();\n42:   };\n43: \n44:   const config = loadConfig(projectDir);\n45: \n46:   const { maxIterations: defaultMax, description } = await callbacks.setup(config, flags.dryRun);\n47:   const maxIterations = flags.maxIterations || defaultMax;\n48:   const runTracker = startRunTracker(projectDir, description, maxIterations);\n49:   const detachTracker = emitter.on((event) => runTracker.recordEvent(event));\n50:   let finalized = false;\n51: \n52:   try {\n53:     emitter.emit({ type: \"loop.description\", description });\n54: \n55:     if (flags.dryRun) {\n56:       let iteration = 0;\n57:       while (iteration < maxIterations) {\n58:         const next = await callbacks.nextIteration(config, iteration + 1);\n59:         if (!next) break;\n60:         iteration++;\n61:         const modelStr = `${next.model.providerID}/${next.model.modelID}`;\n62:         emitter.emit({\n63:           type: \"loop.dry_run_iteration\",\n64:           iteration,\n65:           label: next.iterationLabel,\n66:           model: modelStr,\n67:         });\n68:       }\n69:       emitter.emit({\n70:         type: \"loop.dry_run_complete\",\n71:         iterations: iteration,\n72:         maxIterations,\n73:       });\n74:       runTracker.finalize(\"completed\");\n75:       finalized = true;\n76:       return { completed: 0, failed: 0, skipped: 0, totalTime: 0, maxIterations, iterations: [] };\n77:     }\n78: \n79:     if (flags.attach) {\n80:       server = await connectToServer(flags.attach);\n81:       emitter.emit({ type: \"server.attached\", url: server.url });\n82:     } else {\n83:       server = await startServer();\n84:       emitter.emit({ type: \"server.started\", url: server.url });\n85:       emitter.emit({ type: \"server.attach_hint\", url: server.url });\n86:     }\n87: \n88:     let iteration = 0;\n89:     let completed = 0;\n90:     let failed = 0;\n91:     let skipped = 0;\n92:     const iterations: IterationResult[] = [];\n93:     const retryCount = new Map<string, number>();\n94:     const startTime = Date.now();\n95: \n96:     while (iteration < maxIterations) {\n97:       const next = await callbacks.nextIteration(config, iteration + 1);\n98:       if (!next) break;\n99: \n100:       iteration++;\n101:       const modelStr = `${next.model.providerID}/${next.model.modelID}`;\n102:       emitter.emit({\n103:         type: \"iteration.started\",\n104:         iteration,\n105:         label: next.iterationLabel,\n106:         model: modelStr,\n107:       });\n108: \n109:       const iterStartTime = Date.now();\n110: \n111:       try {\n112:         const sessionId = await createSession(server.client, next.sessionTitle);\n113:         emitter.emit({ type: \"iteration.session_created\", sessionId });\n114: \n115:         const timeoutMs = config.engine.timeout_minutes * 60 * 1000;\n116:         const inactivityTimeoutMs = config.engine.inactivity_timeout_seconds * 1000;\n117:         const promptResult = await withTimeout(\n118:           runPrompt(server.client, sessionId, next.prompt, next.model, next.systemPrompt, server.url, inactivityTimeoutMs),\n119:           timeoutMs,\n120:           `Iteration timed out after ${config.engine.timeout_minutes}m`,\n121:         );\n122:         const result = promptResult.completion;\n123:         const iterDuration = Date.now() - iterStartTime;\n124: \n125:         const iterResult: IterationResult = {\n126:           iteration,\n127:           beadId: next.beadId || `iter-${iteration}`,\n128:           beadTitle: next.iterationLabel,\n129:           status: result.status,\n130:           reason: result.reason,\n131:           model: modelStr,\n132:           duration: iterDuration,\n133:           cost: promptResult.cost,\n134:           tokens: promptResult.tokens,\n135:           filesChanged: promptResult.filesChanged,\n136:         };\n137: \n138:         const transcriptPath = runTracker.writeIterationTranscript(\n139:           iteration,\n140:           next.iterationLabel,\n141:           promptResult.rawOutput,\n142:           promptResult.displayOutput,\n143:         );\n144:         if (transcriptPath) {\n145:           iterResult.transcriptPath = transcriptPath;\n146:         }\n147: \n148:         iterations.push(iterResult);\n149:         appendProgress(projectDir, iteration, iterResult);\n150: \n151:         const shouldContinue = await callbacks.handleResult(result, iteration);\n152: \n153:         if (result.status === \"complete\" || result.status === \"phase_done\") {\n154:           completed++;\n155:           emitter.emit({\n156:             type: \"iteration.completed\",\n157:             iteration,\n158:             label: next.iterationLabel,\n159:             status: result.status,\n160:             reason: result.reason,\n161:           });\n162:         } else if (result.status === \"blocked\") {\n163:           skipped++;\n164:           emitter.emit({\n165:             type: \"iteration.blocked\",\n166:             iteration,\n167:             label: next.iterationLabel,\n168:             reason: result.reason,\n169:           });\n170:         } else {\n171:           const key = next.iterationLabel;\n172:           const currentRetries = retryCount.get(key) || 0;\n173:           if (config.engine.strategy === \"retry\" && currentRetries < config.engine.max_retries) {\n174:             retryCount.set(key, currentRetries + 1);\n175:             emitter.emit({\n176:               type: \"iteration.retrying\",\n177:               iteration,\n178:               label: next.iterationLabel,\n179:               status: result.status,\n180:               attempt: currentRetries + 1,\n181:               maxRetries: config.engine.max_retries,\n182:             });\n183:             iteration--;\n184:           } else if (config.engine.strategy === \"abort\") {\n185:             failed++;\n186:             emitter.emit({\n187:               type: \"iteration.failed\",\n188:               iteration,\n189:               label: next.iterationLabel,\n190:               status: result.status,\n191:               action: \"aborting\",\n192:             });\n193:             break;\n194:           } else {\n195:             failed++;\n196:             emitter.emit({\n197:               type: \"iteration.failed\",\n198:               iteration,\n199:               label: next.iterationLabel,\n200:               status: result.status,\n201:               action: \"skipping\",\n202:             });\n203:           }\n204:         }\n205: \n206:         if (!shouldContinue) break;\n207: \n208:       } catch (err) {\n209:         const iterDuration = Date.now() - iterStartTime;\n210:         const iterResult: IterationResult = {\n211:           iteration,\n212:           beadId: next.beadId || `iter-${iteration}`,\n213:           beadTitle: next.iterationLabel,\n214:           status: \"error\",\n215:           reason: (err as Error).message,\n216:           model: modelStr,\n217:           duration: iterDuration,\n218:         };\n219:         iterations.push(iterResult);\n220:         appendProgress(projectDir, iteration, iterResult);\n221:         failed++;\n222:         emitter.emit({\n223:           type: \"iteration.error\",\n224:           iteration,\n225:           label: next.iterationLabel,\n226:           error: (err as Error).message,\n227:         });\n228:         if (config.engine.strategy === \"abort\") break;\n229:       }\n230: \n231:       if (config.engine.iteration_delay_ms > 0) {\n232:         await new Promise((r) => setTimeout(r, config.engine.iteration_delay_ms));\n233:       }\n234:     }\n235:     const totalTime = Date.now() - startTime;\n236:     emitter.emit({\n237:       type: \"loop.completed\",\n238:       completed,\n239:       failed,\n240:       skipped,\n241:       totalTimeMs: totalTime,\n242:     });\n243: \n244:     runTracker.finalize(failed > 0 ? \"failed\" : \"completed\");\n245:     finalized = true;\n246: \n247:     return { completed, failed, skipped, totalTime, maxIterations, iterations };\n248:   } finally {\n249:     detachTracker();\n250:     if (!finalized) {\n251:       runTracker.finalize(\"failed\");\n252:     }\n253:     cleanup();\n254:   }\n255: }\n\n(End of file - total 255 lines)\n</content>","title":"src/engine.ts","metadata":{"preview":"import { loadConfig } from \"./config.js\";\nimport { startServer, connectToServer, createSession, runPrompt, type ServerHandle } from \"./opencode.js\";\nimport { appendProgress } from \"./progress.js\";\nimport type { LoopConfig, LoopResult, IterationResult, CompletionResult, PhaseFlags } from \"./types.js\";\nimport { EngineEventEmitter, attachDefaultConsoleRenderer, type EngineEventListener } from \"./events.js\";\nimport { startRunTracker } from \"./run-state.js\";\nimport { withTimeout } from \"./timeout.js\";\n\nexport interface PhaseIteration {\n  prompt: string;\n  model: { providerID: string; modelID: string };\n  sessionTitle: string;\n  iterationLabel: string;\n  beadId?: string;\n  systemPrompt?: string;\n}\n\nexport interface PhaseCallbacks {\n  setup(config: LoopConfig, dryRun: boolean): Promise<{ maxIterations: number; description: string }>;\n  nextIteration(config: LoopConfig, iteration: number): Promise<PhaseIteration | null>;","truncated":false,"loaded":[]},"time":{"start":1772179442761,"end":1772179442773}}}}
