{"type":"tool_use","timestamp":1772180963572,"sessionID":"ses_361cb8d0cffebVDrnflLw7abix","part":{"id":"prt_c9e377dff001R0rOMx6AggBZBR","sessionID":"ses_361cb8d0cffebVDrnflLw7abix","messageID":"msg_c9e37781f001KlruMqCnfXOZaz","type":"tool","callID":"toolu_01U5Ui3xPMuxvQtVYXqZm7gz","tool":"read","state":{"status":"completed","input":{"filePath":"/Users/mat/dev/farsight/agent-framework/src/run-state.ts"},"output":"<path>/Users/mat/dev/farsight/agent-framework/src/run-state.ts</path>\n<type>file</type>\n<content>1: import { appendFileSync, existsSync, mkdirSync, writeFileSync } from \"fs\";\n2: import { join } from \"path\";\n3: import type { EngineEvent } from \"./events.js\";\n4: \n5: export interface RunTracker {\n6:   runId: string;\n7:   runDir: string;\n8:   recordEvent(event: EngineEvent): void;\n9:   writeIterationTranscript(iteration: number, label: string, rawOutput?: string, displayOutput?: string): string | undefined;\n10:   finalize(status: \"completed\" | \"failed\"): void;\n11: }\n12: \n13: interface SessionState {\n14:   runId: string;\n15:   status: \"running\" | \"completed\" | \"failed\";\n16:   description: string;\n17:   maxIterations: number;\n18:   startedAt: string;\n19:   updatedAt: string;\n20:   currentIteration: number;\n21:   completed: number;\n22:   failed: number;\n23:   skipped: number;\n24: }\n25: \n26: function nowIso(): string {\n27:   return new Date().toISOString();\n28: }\n29: \n30: function sanitizeName(label: string): string {\n31:   return label\n32:     .toLowerCase()\n33:     .replace(/[^a-z0-9]+/g, \"-\")\n34:     .replace(/^-+|-+$/g, \"\")\n35:     .slice(0, 80) || \"iteration\";\n36: }\n37: \n38: export function startRunTracker(projectDir: string, description: string, maxIterations: number): RunTracker {\n39:   const baseDir = join(projectDir, \".super-ralph\", \"runs\");\n40:   if (!existsSync(baseDir)) {\n41:     mkdirSync(baseDir, { recursive: true });\n42:   }\n43: \n44:   const runId = `${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;\n45:   const runDir = join(baseDir, runId);\n46:   const iterationsDir = join(runDir, \"iterations\");\n47:   mkdirSync(iterationsDir, { recursive: true });\n48: \n49:   const statePath = join(runDir, \"session.json\");\n50:   const globalStatePath = join(projectDir, \".super-ralph\", \"session.json\");\n51:   const eventsPath = join(runDir, \"events.jsonl\");\n52: \n53:   const state: SessionState = {\n54:     runId,\n55:     status: \"running\",\n56:     description,\n57:     maxIterations,\n58:     startedAt: nowIso(),\n59:     updatedAt: nowIso(),\n60:     currentIteration: 0,\n61:     completed: 0,\n62:     failed: 0,\n63:     skipped: 0,\n64:   };\n65: \n66:   const writeState = () => {\n67:     state.updatedAt = nowIso();\n68:     writeFileSync(statePath, JSON.stringify(state, null, 2) + \"\\n\");\n69:     writeFileSync(globalStatePath, JSON.stringify(state, null, 2) + \"\\n\");\n70:   };\n71: \n72:   const updateFromEvent = (event: EngineEvent) => {\n73:     switch (event.type) {\n74:       case \"iteration.started\":\n75:         state.currentIteration = event.iteration;\n76:         break;\n77:       case \"iteration.completed\":\n78:         state.completed += 1;\n79:         break;\n80:       case \"iteration.blocked\":\n81:         state.skipped += 1;\n82:         break;\n83:       case \"iteration.failed\":\n84:       case \"iteration.error\":\n85:         state.failed += 1;\n86:         break;\n87:       case \"loop.completed\":\n88:         state.completed = event.completed;\n89:         state.failed = event.failed;\n90:         state.skipped = event.skipped;\n91:         break;\n92:       default:\n93:         break;\n94:     }\n95:   };\n96: \n97:   writeState();\n98: \n99:   return {\n100:     runId,\n101:     runDir,\n102:     recordEvent(event: EngineEvent) {\n103:       appendFileSync(eventsPath, JSON.stringify({ ts: nowIso(), event }) + \"\\n\");\n104:       updateFromEvent(event);\n105:       writeState();\n106:     },\n107:     writeIterationTranscript(iteration: number, label: string, rawOutput?: string, displayOutput?: string) {\n108:       const hasRaw = !!rawOutput && rawOutput.trim().length > 0;\n109:       const hasDisplay = !!displayOutput && displayOutput.trim().length > 0;\n110:       if (!hasRaw && !hasDisplay) return undefined;\n111: \n112:       const filename = `${String(iteration).padStart(3, \"0\")}-${sanitizeName(label)}.log`;\n113:       const relPath = join(\".super-ralph\", \"runs\", runId, \"iterations\", filename);\n114:       const absPath = join(iterationsDir, filename);\n115: \n116:       let body = \"\";\n117:       body += `# Iteration ${iteration} Transcript\\n`;\n118:       body += `# Label: ${label}\\n\\n`;\n119:       if (hasDisplay) {\n120:         body += \"## Display Stream\\n\\n\";\n121:         body += `${displayOutput}\\n\\n`;\n122:       }\n123:       if (hasRaw) {\n124:         body += \"## Raw Event Stream\\n\\n\";\n125:         body += `${rawOutput}\\n`;\n126:       }\n127:       writeFileSync(absPath, body);\n128:       return relPath;\n129:     },\n130:     finalize(status: \"completed\" | \"failed\") {\n131:       state.status = status;\n132:       writeState();\n133:     },\n134:   };\n135: }\n\n(End of file - total 135 lines)\n</content>","title":"src/run-state.ts","metadata":{"preview":"import { appendFileSync, existsSync, mkdirSync, writeFileSync } from \"fs\";\nimport { join } from \"path\";\nimport type { EngineEvent } from \"./events.js\";\n\nexport interface RunTracker {\n  runId: string;\n  runDir: string;\n  recordEvent(event: EngineEvent): void;\n  writeIterationTranscript(iteration: number, label: string, rawOutput?: string, displayOutput?: string): string | undefined;\n  finalize(status: \"completed\" | \"failed\"): void;\n}\n\ninterface SessionState {\n  runId: string;\n  status: \"running\" | \"completed\" | \"failed\";\n  description: string;\n  maxIterations: number;\n  startedAt: string;\n  updatedAt: string;\n  currentIteration: number;","truncated":false,"loaded":[]},"time":{"start":1772180963565,"end":1772180963571}}}}
{"type":"tool_use","timestamp":1772180964037,"sessionID":"ses_361cb8d0cffebVDrnflLw7abix","part":{"id":"prt_c9e3780f0001de8fcLzONLejL3","sessionID":"ses_361cb8d0cffebVDrnflLw7abix","messageID":"msg_c9e37781f001KlruMqCnfXOZaz","type":"tool","callID":"toolu_01P2XM4Qwv1PdN8X8eks5gLe","tool":"read","state":{"status":"completed","input":{"filePath":"/Users/mat/dev/farsight/agent-framework/src/engine.ts"},"output":"<path>/Users/mat/dev/farsight/agent-framework/src/engine.ts</path>\n<type>file</type>\n<content>1: import { loadConfig } from \"./config.js\";\n2: import { startServer, connectToServer, createSession, runPrompt, type ServerHandle } from \"./opencode.js\";\n3: import { appendProgress } from \"./progress.js\";\n4: import type { LoopConfig, LoopResult, IterationResult, CompletionResult, PhaseFlags } from \"./types.js\";\n5: import { EngineEventEmitter, attachDefaultConsoleRenderer, type EngineEventListener } from \"./events.js\";\n6: import { startRunTracker } from \"./run-state.js\";\n7: import { withTimeout } from \"./timeout.js\";\n8: \n9: export interface PhaseIteration {\n10:   prompt: string;\n11:   model: { providerID: string; modelID: string };\n12:   sessionTitle: string;\n13:   iterationLabel: string;\n14:   beadId?: string;\n15:   systemPrompt?: string;\n16: }\n17: \n18: export interface PhaseCallbacks {\n19:   setup(config: LoopConfig, dryRun: boolean): Promise<{ maxIterations: number; description: string }>;\n20:   nextIteration(config: LoopConfig, iteration: number): Promise<PhaseIteration | null>;\n21:   handleResult(result: CompletionResult, iteration: number): Promise<boolean>;\n22: }\n23: \n24: export async function runPhaseLoop(\n25:   projectDir: string,\n26:   callbacks: PhaseCallbacks,\n27:   flags: PhaseFlags,\n28:   onEvent?: EngineEventListener,\n29: ): Promise<LoopResult> {\n30:   const emitter = new EngineEventEmitter();\n31:   const detachConsole = attachDefaultConsoleRenderer(emitter);\n32:   const detachExternal = onEvent ? emitter.on(onEvent) : null;\n33: \n34:   let server: ServerHandle | undefined;\n35: \n36:   const cleanup = () => {\n37:     if (server) {\n38:       server.close();\n39:     }\n40:     detachConsole();\n41:     if (detachExternal) detachExternal();\n42:   };\n43: \n44:   const config = loadConfig(projectDir);\n45: \n46:   const { maxIterations: defaultMax, description } = await callbacks.setup(config, flags.dryRun);\n47:   const maxIterations = flags.maxIterations || defaultMax;\n48:   const runTracker = startRunTracker(projectDir, description, maxIterations);\n49:   const detachTracker = emitter.on((event) => runTracker.recordEvent(event));\n50:   let finalized = false;\n51: \n52:   try {\n53:     emitter.emit({ type: \"loop.description\", description });\n54: \n55:     if (flags.dryRun) {\n56:       let iteration = 0;\n57:       while (iteration < maxIterations) {\n58:         const next = await callbacks.nextIteration(config, iteration + 1);\n59:         if (!next) break;\n60:         iteration++;\n61:         const modelStr = `${next.model.providerID}/${next.model.modelID}`;\n62:         emitter.emit({\n63:           type: \"loop.dry_run_iteration\",\n64:           iteration,\n65:           label: next.iterationLabel,\n66:           model: modelStr,\n67:         });\n68:       }\n69:       emitter.emit({\n70:         type: \"loop.dry_run_complete\",\n71:         iterations: iteration,\n72:         maxIterations,\n73:       });\n74:       runTracker.finalize(\"completed\");\n75:       finalized = true;\n76:       return { completed: 0, failed: 0, skipped: 0, totalTime: 0, maxIterations, iterations: [] };\n77:     }\n78: \n79:     if (flags.attach) {\n80:       server = await connectToServer(flags.attach);\n81:       emitter.emit({ type: \"server.attached\", url: server.url });\n82:     } else {\n83:       server = await startServer();\n84:       emitter.emit({ type: \"server.started\", url: server.url });\n85:       emitter.emit({ type: \"server.attach_hint\", url: server.url });\n86:     }\n87: \n88:     let iteration = 0;\n89:     let completed = 0;\n90:     let failed = 0;\n91:     let skipped = 0;\n92:     const iterations: IterationResult[] = [];\n93:     const retryCount = new Map<string, number>();\n94:     const startTime = Date.now();\n95: \n96:     while (iteration < maxIterations) {\n97:       const next = await callbacks.nextIteration(config, iteration + 1);\n98:       if (!next) break;\n99: \n100:       iteration++;\n101:       const modelStr = `${next.model.providerID}/${next.model.modelID}`;\n102:       emitter.emit({\n103:         type: \"iteration.started\",\n104:         iteration,\n105:         label: next.iterationLabel,\n106:         model: modelStr,\n107:       });\n108: \n109:       const iterStartTime = Date.now();\n110: \n111:       try {\n112:         const sessionId = await createSession(server.client, next.sessionTitle);\n113:         emitter.emit({ type: \"iteration.session_created\", sessionId });\n114: \n115:         const timeoutMs = config.engine.timeout_minutes * 60 * 1000;\n116:         const inactivityTimeoutMs = config.engine.inactivity_timeout_seconds * 1000;\n117:         const promptResult = await withTimeout(\n118:           runPrompt(server.client, sessionId, next.prompt, next.model, next.systemPrompt, server.url, inactivityTimeoutMs),\n119:           timeoutMs,\n120:           `Iteration timed out after ${config.engine.timeout_minutes}m`,\n121:         );\n122:         const result = promptResult.completion;\n123:         const iterDuration = Date.now() - iterStartTime;\n124: \n125:         const iterResult: IterationResult = {\n126:           iteration,\n127:           beadId: next.beadId || `iter-${iteration}`,\n128:           beadTitle: next.iterationLabel,\n129:           status: result.status,\n130:           reason: result.reason,\n131:           model: modelStr,\n132:           duration: iterDuration,\n133:           cost: promptResult.cost,\n134:           tokens: promptResult.tokens,\n135:           filesChanged: promptResult.filesChanged,\n136:         };\n137: \n138:         const transcriptPath = runTracker.writeIterationTranscript(\n139:           iteration,\n140:           next.iterationLabel,\n141:           promptResult.rawOutput,\n142:           promptResult.displayOutput,\n143:         );\n144:         if (transcriptPath) {\n145:           iterResult.transcriptPath = transcriptPath;\n146:         }\n147: \n148:         iterations.push(iterResult);\n149:         appendProgress(projectDir, iteration, iterResult);\n150: \n151:         const shouldContinue = await callbacks.handleResult(result, iteration);\n152: \n153:         if (result.status === \"complete\" || result.status === \"phase_done\") {\n154:           completed++;\n155:           emitter.emit({\n156:             type: \"iteration.completed\",\n157:             iteration,\n158:             label: next.iterationLabel,\n159:             status: result.status,\n160:             reason: result.reason,\n161:           });\n162:         } else if (result.status === \"blocked\") {\n163:           skipped++;\n164:           emitter.emit({\n165:             type: \"iteration.blocked\",\n166:             iteration,\n167:             label: next.iterationLabel,\n168:             reason: result.reason,\n169:           });\n170:         } else {\n171:           const key = next.iterationLabel;\n172:           const currentRetries = retryCount.get(key) || 0;\n173:           if (config.engine.strategy === \"retry\" && currentRetries < config.engine.max_retries) {\n174:             retryCount.set(key, currentRetries + 1);\n175:             emitter.emit({\n176:               type: \"iteration.retrying\",\n177:               iteration,\n178:               label: next.iterationLabel,\n179:               status: result.status,\n180:               attempt: currentRetries + 1,\n181:               maxRetries: config.engine.max_retries,\n182:             });\n183:             iteration--;\n184:           } else if (config.engine.strategy === \"abort\") {\n185:             failed++;\n186:             emitter.emit({\n187:               type: \"iteration.failed\",\n188:               iteration,\n189:               label: next.iterationLabel,\n190:               status: result.status,\n191:               action: \"aborting\",\n192:             });\n193:             break;\n194:           } else {\n195:             failed++;\n196:             emitter.emit({\n197:               type: \"iteration.failed\",\n198:               iteration,\n199:               label: next.iterationLabel,\n200:               status: result.status,\n201:               action: \"skipping\",\n202:             });\n203:           }\n204:         }\n205: \n206:         if (!shouldContinue) break;\n207: \n208:       } catch (err) {\n209:         const iterDuration = Date.now() - iterStartTime;\n210:         const iterResult: IterationResult = {\n211:           iteration,\n212:           beadId: next.beadId || `iter-${iteration}`,\n213:           beadTitle: next.iterationLabel,\n214:           status: \"error\",\n215:           reason: (err as Error).message,\n216:           model: modelStr,\n217:           duration: iterDuration,\n218:         };\n219:         iterations.push(iterResult);\n220:         appendProgress(projectDir, iteration, iterResult);\n221:         failed++;\n222:         emitter.emit({\n223:           type: \"iteration.error\",\n224:           iteration,\n225:           label: next.iterationLabel,\n226:           error: (err as Error).message,\n227:         });\n228:         if (config.engine.strategy === \"abort\") break;\n229:       }\n230: \n231:       if (config.engine.iteration_delay_ms > 0) {\n232:         await new Promise((r) => setTimeout(r, config.engine.iteration_delay_ms));\n233:       }\n234:     }\n235:     const totalTime = Date.now() - startTime;\n236:     emitter.emit({\n237:       type: \"loop.completed\",\n238:       completed,\n239:       failed,\n240:       skipped,\n241:       totalTimeMs: totalTime,\n242:     });\n243: \n244:     runTracker.finalize(failed > 0 ? \"failed\" : \"completed\");\n245:     finalized = true;\n246: \n247:     return { completed, failed, skipped, totalTime, maxIterations, iterations };\n248:   } finally {\n249:     detachTracker();\n250:     if (!finalized) {\n251:       runTracker.finalize(\"failed\");\n252:     }\n253:     cleanup();\n254:   }\n255: }\n\n(End of file - total 255 lines)\n</content>","title":"src/engine.ts","metadata":{"preview":"import { loadConfig } from \"./config.js\";\nimport { startServer, connectToServer, createSession, runPrompt, type ServerHandle } from \"./opencode.js\";\nimport { appendProgress } from \"./progress.js\";\nimport type { LoopConfig, LoopResult, IterationResult, CompletionResult, PhaseFlags } from \"./types.js\";\nimport { EngineEventEmitter, attachDefaultConsoleRenderer, type EngineEventListener } from \"./events.js\";\nimport { startRunTracker } from \"./run-state.js\";\nimport { withTimeout } from \"./timeout.js\";\n\nexport interface PhaseIteration {\n  prompt: string;\n  model: { providerID: string; modelID: string };\n  sessionTitle: string;\n  iterationLabel: string;\n  beadId?: string;\n  systemPrompt?: string;\n}\n\nexport interface PhaseCallbacks {\n  setup(config: LoopConfig, dryRun: boolean): Promise<{ maxIterations: number; description: string }>;\n  nextIteration(config: LoopConfig, iteration: number): Promise<PhaseIteration | null>;","truncated":false,"loaded":[]},"time":{"start":1772180964034,"end":1772180964037}}}}
