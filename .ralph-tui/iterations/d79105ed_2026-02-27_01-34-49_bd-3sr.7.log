 model: string;\n55:   duration: number; // milliseconds\n56:   cost?: number;\n57:   tokens?: { input: number; output: number; reasoning: number };\n58:   filesChanged?: string[];\n59:   transcriptPath?: string;\n60: }\n61: \n62: // Completion result from OpenCode session\n63: export interface CompletionResult {\n64:   status: \"complete\" | \"phase_done\" | \"blocked\" | \"failed\" | \"stalled\" | \"timeout\" | \"error\";\n65:   reason?: string;\n66: }\n67: \n68: // Overall loop result\n69: export interface LoopResult {\n70:   completed: number;\n71:   failed: number;\n72:   skipped: number;\n73:   totalTime: number; // milliseconds\n74:   maxIterations: number;\n75:   iterations: IterationResult[];\n76: }\n77: \n78: // Common flags shared by all three phases\n79: export interface PhaseFlags {\n80:   dryRun: boolean;\n81:   maxIterations?: number;\n82:   modelOverride?: string;\n83:   attach?: string; // URL to attach to existing OpenCode server instead of spawning one\n84: }\n85: \n86: export interface ForwardFlags extends PhaseFlags {\n87:   epicId: string;\n88: }\n89: \n90: export interface DecomposeFlags extends PhaseFlags {\n91:   specPath: string;\n92:   epicTitle?: string;\n93: }\n94: \n95: export interface ReverseFlags extends PhaseFlags {\n96:   inputs: string[];         // paths, URLs, descriptions — anything (positional args)\n97:   outputDir?: string;\n98:   skill?: string;           // --skill <name-or-path> — question bank\n99:   interactive?: boolean;    // --interactive — force interactive mode (default when no inputs)\n100:   answersFile?: string;     // --answers <path> — JSON file with pre-recorded answers for non-interactive testing\n101: }\n102: \n103: export type ErrorStrategy = \"retry\" | \"skip\" | \"abort\";\n\n(End of file - total 103 lines)\n</content>","title":"src/types.ts","metadata":{"preview":"// Bead information from br CLI\nexport interface BeadInfo {\n  id: string;\n  title: string;\n  description?: string;\n  status: \"open\" | \"in_progress\" | \"closed\";\n  labels: string[];\n  priority: number; // 0-4 (0 = critical)\n  dependsOn: string[];\n  blocks: string[];\n  type?: string; // epic, task, etc.\n  parentId?: string;\n}\n\n// Loop configuration from .super-ralph/config.toml\nexport interface LoopConfig {\n  engine: {\n    timeout_minutes: number;\n    inactivity_timeout_seconds: number;\n    iteration_delay_ms: number;","truncated":false,"loaded":[]},"time":{"start":1772181450252,"end":1772181450258}}}}
