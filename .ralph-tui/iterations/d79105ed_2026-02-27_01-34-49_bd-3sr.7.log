{"type":"tool_use","timestamp":1772181452204,"sessionID":"ses_361c37f15ffeuVWV0XN4ZPvLel","part":{"id":"prt_c9e3ef3b5001lFJcqWGyxh2giN","sessionID":"ses_361c37f15ffeuVWV0XN4ZPvLel","messageID":"msg_c9e3eeffa001DpcNVa4Mzsovxo","type":"tool","callID":"toolu_01U1JFKX9PVT7AoeFuc3XLHQ","tool":"read","state":{"status":"completed","input":{"filePath":"/Users/mat/dev/farsight/agent-framework/src/config.ts"},"output":"<path>/Users/mat/dev/farsight/agent-framework/src/config.ts</path>\n<type>file</type>\n<content>1: import { readFileSync, existsSync } from \"fs\";\n2: import { join } from \"path\";\n3: import { parse as parseTOML } from \"@iarna/toml\";\n4: import type { LoopConfig, ErrorStrategy } from \"./types.js\";\n5: \n6: const DEFAULT_CONFIG: LoopConfig = {\n7:   engine: {\n8:     timeout_minutes: 30,\n9:     inactivity_timeout_seconds: 180,\n10:     iteration_delay_ms: 2000,\n11:     strategy: \"retry\",\n12:     max_retries: 3,\n13:   },\n14:   opencode: {\n15:     url: \"http://localhost:4096\",\n16:   },\n17:   cli: {\n18:     path: \"\",\n19:   },\n20:   models: {\n21:     default: \"anthropic/claude-sonnet-4-6\",\n22:   },\n23:   modelsAreas: {},\n24:   reverse: {\n25:     output_dir: \"docs/specs\",\n26:   },\n27:   decompose: {\n28:     include_review: true,\n29:     include_bugscan: true,\n30:     include_audit: true,\n31:   },\n32: };\n33: \n34: export function loadConfig(projectDir: string): LoopConfig {\n35:   const configPath = join(projectDir, \".super-ralph\", \"config.toml\");\n36:   if (!existsSync(configPath)) {\n37:     return { ...DEFAULT_CONFIG };\n38:   }\n39:   \n40:   const raw = readFileSync(configPath, \"utf-8\");\n41:   const parsed = parseTOML(raw);\n42:   \n43:   // Extract models, separating the nested areas sub-object from flat model strings\n44:   const parsedModels = (parsed.models || {}) as Record<string, unknown>;\n45:   const parsedAreas = (parsedModels.areas || {}) as Record<string, string>;\n46: \n47:   // Build models without the areas sub-object (only flat string values)\n48:   const flatModels: Record<string, string> = {};\n49:   for (const [key, value] of Object.entries(parsedModels)) {\n50:     if (key !== \"areas\" && typeof value === \"string\") {\n51:       flatModels[key] = value;\n52:     }\n53:   }\n54: \n55:   // Deep merge with defaults\n56:   return {\n57:     engine: {\n58:       ...DEFAULT_CONFIG.engine,\n59:       ...(parsed.engine as Record<string, unknown> || {}),\n60:       strategy: ((parsed.engine as Record<string, unknown>)?.strategy as ErrorStrategy) || DEFAULT_CONFIG.engine.strategy,\n61:     },\n62:     opencode: {\n63:       ...DEFAULT_CONFIG.opencode,\n64:       ...(parsed.opencode as Record<string, unknown> || {}),\n65:     },\n66:     cli: {\n67:       ...DEFAULT_CONFIG.cli,\n68:       ...(parsed.cli as Record<string, unknown> || {}),\n69:     },\n70:     models: {\n71:       ...DEFAULT_CONFIG.models,\n72:       ...flatModels,\n73:     },\n74:     modelsAreas: {\n75:       ...parsedAreas,\n76:     },\n77:     reverse: {\n78:       ...DEFAULT_CONFIG.reverse,\n79:       ...((parsed.reverse as Record<string, unknown>) || {}),\n80:     },\n81:     decompose: {\n82:       ...DEFAULT_CONFIG.decompose,\n83:       ...((parsed.decompose as Record<string, unknown>) || {}),\n84:     },\n85:   };\n86: }\n87: \n88: export function resolveModel(\n89:   beadLabels: string[],\n90:   beadTitle: string,\n91:   config: LoopConfig,\n92:   cliOverride?: string\n93: ): { providerID: string; modelID: string } {\n94:   let modelString: string;\n95:   \n96:   // Priority 1: CLI override\n97:   if (cliOverride) {\n98:     modelString = cliOverride;\n99:   } else {\n100:     // Priority 2: Bead area label -> models.areas mapping\n101:     const areaLabel = beadLabels.find((l) => l.startsWith(\"area:\"));\n102:     if (areaLabel) {\n103:       const area = areaLabel.slice(5); // strip \"area:\"\n104:       const areaModel = config.modelsAreas[area];\n105:       if (areaModel) {\n106:         modelString = areaModel;\n107:       } else {\n108:         // Fall through to default\n109:         modelString = config.models.default;\n110:       }\n111:     } else {\n112:       // Priority 3: Default\n113:       modelString = config.models.default;\n114:     }\n115:   }\n116:   \n117:   // Parse provider/model format\n118:   const slashIndex = modelString.indexOf(\"/\");\n119:   if (slashIndex === -1) {\n120:     throw new Error(`Invalid model format \"${modelString}\" — expected \"provider/model\" (e.g., \"anthropic/claude-sonnet-4-6\")`);\n121:   }\n122:   \n123:   return {\n124:     providerID: modelString.slice(0, slashIndex),\n125:     modelID: modelString.slice(slashIndex + 1),\n126:   };\n127: }\n\n(End of file - total 127 lines)\n</content>","title":"src/config.ts","metadata":{"preview":"import { readFileSync, existsSync } from \"fs\";\nimport { join } from \"path\";\nimport { parse as parseTOML } from \"@iarna/toml\";\nimport type { LoopConfig, ErrorStrategy } from \"./types.js\";\n\nconst DEFAULT_CONFIG: LoopConfig = {\n  engine: {\n    timeout_minutes: 30,\n    inactivity_timeout_seconds: 180,\n    iteration_delay_ms: 2000,\n    strategy: \"retry\",\n    max_retries: 3,\n  },\n  opencode: {\n    url: \"http://localhost:4096\",\n  },\n  cli: {\n    path: \"\",\n  },\n  models: {","truncated":false,"loaded":[]},"time":{"start":1772181452195,"end":1772181452202}}}}
{"type":"tool_use","timestamp":1772181452664,"sessionID":"ses_361c37f15ffeuVWV0XN4ZPvLel","part":{"id":"prt_c9e3ef5a6001FF56bw4VUMF8wn","sessionID":"ses_361c37f15ffeuVWV0XN4ZPvLel","messageID":"msg_c9e3eeffa001DpcNVa4Mzsovxo","type":"tool","callID":"toolu_015p6uk1WdkVboSKN2gyagRU","tool":"read","state":{"status":"completed","input":{"filePath":"/Users/mat/dev/farsight/agent-framework/src/beads.ts"},"output":"<path>/Users/mat/dev/farsight/agent-framework/src/beads.ts</path>\n<type>file</type>\n<content>1: import type { BeadInfo } from \"./types.js\";\n2: \n3: // Run a br CLI command and return parsed JSON\n4: export async function runBr(args: string[], cwd?: string): Promise<unknown> {\n5:   const proc = Bun.spawn([\"br\", ...args], {\n6:     cwd: cwd || process.cwd(),\n7:     stdout: \"pipe\",\n8:     stderr: \"pipe\",\n9:   });\n10: \n11:   const stdout = await new Response(proc.stdout).text();\n12:   const stderr = await new Response(proc.stderr).text();\n13:   const exitCode = await proc.exited;\n14: \n15:   if (exitCode !== 0) {\n16:     throw new Error(`br ${args.join(\" \")} failed (exit ${exitCode}): ${stderr}`);\n17:   }\n18: \n19:   // Filter out log lines (br outputs INFO/WARN lines to stdout before JSON in some cases)\n20:   // JSON output may be pretty-printed across multiple lines, so find the first line\n21:   // that starts a JSON array or object, then take everything from there onwards.\n22:   const lines = stdout.trim().split(\"\\n\");\n23:   const jsonStartIdx = lines.findIndex((line) => line.startsWith(\"[\") || line.startsWith(\"{\"));\n24:   if (jsonStartIdx === -1) {\n25:     // Empty result is valid (e.g., no ready beads)\n26:     return [];\n27:   }\n28: \n29:   const jsonStr = lines.slice(jsonStartIdx).join(\"\\n\");\n30:   return JSON.parse(jsonStr);\n31: }\n32: \n33: // Map br's snake_case JSON to our BeadInfo type\n34: function mapBead(raw: Record<string, unknown>): BeadInfo {\n35:   return {\n36:     id: raw.id as string,\n37:     title: raw.title as string,\n38:     description: (raw.description as string) || undefined,\n39:     status: mapStatus(raw.status as string),\n40:     labels: (raw.labels as string[]) || [],\n41:     priority: (raw.priority as number) || 3,\n42:     dependsOn: (raw.depends_on as string[]) || (raw.dependsOn as string[]) || [],\n43:     blocks: (raw.blocks as string[]) || [],\n44:     type: (raw.type as string) || undefined,\n45:     parentId: (raw.parent_id as string) || (raw.parentId as string) || undefined,\n46:   };\n47: }\n48: \n49: function mapStatus(status: string): BeadInfo[\"status\"] {\n50:   switch (status) {\n51:     case \"open\":\n52:       return \"open\";\n53:     case \"in_progress\":\n54:     case \"in-progress\":\n55:       return \"in_progress\";\n56:     case \"closed\":\n57:     case \"done\":\n58:     case \"completed\":\n59:       return \"closed\";\n60:     default:\n61:       return \"open\";\n62:   }\n63: }\n64: // Get ALL ready (unblocked) beads in an epic — agent picks from these\n65: export async function getAllReady(epicId: string): Promise<BeadInfo[]> {\n66:   const result = await runBr([\"ready\", \"--parent\", epicId, \"--json\", \"--sort\", \"hybrid\"]);\n67:   const beads = result as Record<string, unknown>[];\n68:   if (!beads || beads.length === 0) return [];\n69:   return beads.map(mapBead);\n70: }\n71: \n72: // Get full details for a specific bead\n73: export async function getBeadDetails(beadId: string): Promise<BeadInfo> {\n74:   const result = await runBr([\"show\", beadId, \"--json\"]);\n75:   // br show returns a single object (or array with one element)\n76:   const raw = Array.isArray(result) ? result[0] : result;\n77:   return mapBead(raw as Record<string, unknown>);\n78: }\n79: \n80: // Close a bead and get newly unblocked beads\n81: export async function closeBead(beadId: string, reason?: string): Promise<{ suggestNext: BeadInfo[] }> {\n82:   const args = [\"close\", beadId, \"--suggest-next\", \"--json\"];\n83:   if (reason) {\n84:     args.push(\"--reason\", reason);\n85:   }\n86:   const result = await runBr(args);\n87:   // The suggest-next output format may vary — handle both array and object\n88:   const raw = result as Record<string, unknown> | Record<string, unknown>[];\n89:   if (Array.isArray(raw)) {\n90:     return { suggestNext: raw.map(mapBead) };\n91:   }\n92:   // If it returns an object with a suggestions/next field\n93:   const suggestions = (raw.suggest_next || raw.suggestNext || raw.suggestions || []) as Record<string, unknown>[];\n94:   return { suggestNext: Array.isArray(suggestions) ? suggestions.map(mapBead) : [] };\n95: }\n96: \n97: // Get all beads in an epic\n98: // Uses `br show` to get child IDs from the dependents array, then `br list --id` to get full details\n99: export async function getAllBeads(epicId: string): Promise<BeadInfo[]> {\n100:   // First, get the epic to extract child IDs from its dependents\n101:   const epicResult = await runBr([\"show\", epicId, \"--json\"]);\n102:   const epicRaw = Array.isArray(epicResult) ? epicResult[0] : epicResult;\n103:   const epic = epicRaw as Record<string, unknown>;\n104: \n105:   const dependents = (epic.dependents || []) as Record<string, unknown>[];\n106:   const childIds = dependents\n107:     .filter((d) => d.dependency_type === \"parent-child\")\n108:     .map((d) => d.id as string);\n109: \n110:   if (childIds.length === 0) return [];\n111: \n112:   // Fetch full details for all children using --id filters\n113:   const args = [\"list\", \"--all\", \"--json\"];\n114:   for (const id of childIds) {\n115:     args.push(\"--id\", id);\n116:   }\n117:   const result = await runBr(args);\n118:   const beads = result as Record<string, unknown>[];\n119:   return beads.map(mapBead);\n120: }\n121: \n122: // Get epic progress summary\n123: export async function getEpicProgress(epicId: string): Promise<{ total: number; completed: number; remaining: number }> {\n124:   const beads = await getAllBeads(epicId);\n125:   const completed = beads.filter((b) => b.status === \"closed\").length;\n126:   return {\n127:     total: beads.length,\n128:     completed,\n129:     remaining: beads.length - completed,\n130:   };\n131: }\n\n(End of file - total 131 lines)\n</content>","title":"src/beads.ts","metadata":{"preview":"import type { BeadInfo } from \"./types.js\";\n\n// Run a br CLI command and return parsed JSON\nexport async function runBr(args: string[], cwd?: string): Promise<unknown> {\n  const proc = Bun.spawn([\"br\", ...args], {\n    cwd: cwd || process.cwd(),\n    stdout: \"pipe\",\n    stderr: \"pipe\",\n  });\n\n  const stdout = await new Response(proc.stdout).text();\n  const stderr = await new Response(proc.stderr).text();\n  const exitCode = await proc.exited;\n\n  if (exitCode !== 0) {\n    throw new Error(`br ${args.join(\" \")} failed (exit ${exitCode}): ${stderr}`);\n  }\n\n  // Filter out log lines (br outputs INFO/WARN lines to stdout before JSON in some cases)\n  // JSON output may be pretty-printed across multiple lines, so find the first line","truncated":false,"loaded":[]},"time":{"start":1772181452661,"end":1772181452663}}}}
