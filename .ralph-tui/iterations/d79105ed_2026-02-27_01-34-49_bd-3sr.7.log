{"type":"tool_use","timestamp":1772181447826,"sessionID":"ses_361c37f15ffeuVWV0XN4ZPvLel","part":{"id":"prt_c9e3ee1380014HU29Ud2MPKgtJ","sessionID":"ses_361c37f15ffeuVWV0XN4ZPvLel","messageID":"msg_c9e3edad0001f7NP8UkAoywKhP","type":"tool","callID":"toolu_01YJAV5UkXeuCVA2xJL3CCWz","tool":"read","state":{"status":"completed","input":{"filePath":"/Users/mat/dev/farsight/agent-framework/src/engine.ts"},"output":"<path>/Users/mat/dev/farsight/agent-framework/src/engine.ts</path>\n<type>file</type>\n<content>1: import { loadConfig } from \"./config.js\";\n2: import { startServer, connectToServer, createSession, runPrompt, type ServerHandle } from \"./opencode.js\";\n3: import { appendProgress } from \"./progress.js\";\n4: import type { LoopConfig, LoopResult, IterationResult, CompletionResult, PhaseFlags } from \"./types.js\";\n5: import { EngineEventEmitter, attachDefaultConsoleRenderer, type EngineEventListener } from \"./events.js\";\n6: import { startRunTracker } from \"./run-state.js\";\n7: import { withTimeout } from \"./timeout.js\";\n8: \n9: export interface PhaseIteration {\n10:   prompt: string;\n11:   model: { providerID: string; modelID: string };\n12:   sessionTitle: string;\n13:   iterationLabel: string;\n14:   beadId?: string;\n15:   systemPrompt?: string;\n16: }\n17: \n18: export interface PhaseCallbacks {\n19:   setup(config: LoopConfig, dryRun: boolean): Promise<{ maxIterations: number; description: string }>;\n20:   nextIteration(config: LoopConfig, iteration: number): Promise<PhaseIteration | null>;\n21:   handleResult(result: CompletionResult, iteration: number): Promise<boolean>;\n22: }\n23: \n24: export async function runPhaseLoop(\n25:   projectDir: string,\n26:   callbacks: PhaseCallbacks,\n27:   flags: PhaseFlags,\n28:   onEvent?: EngineEventListener,\n29: ): Promise<LoopResult> {\n30:   const emitter = new EngineEventEmitter();\n31:   const detachConsole = attachDefaultConsoleRenderer(emitter);\n32:   const detachExternal = onEvent ? emitter.on(onEvent) : null;\n33: \n34:   let server: ServerHandle | undefined;\n35: \n36:   const cleanup = () => {\n37:     if (server) {\n38:       server.close();\n39:     }\n40:     detachConsole();\n41:     if (detachExternal) detachExternal();\n42:   };\n43: \n44:   const config = loadConfig(projectDir);\n45: \n46:   const { maxIterations: defaultMax, description } = await callbacks.setup(config, flags.dryRun);\n47:   const maxIterations = flags.maxIterations || defaultMax;\n48:   const runTracker = startRunTracker(projectDir, description, maxIterations);\n49:   const detachTracker = emitter.on((event) => runTracker.recordEvent(event));\n50:   let finalized = false;\n51: \n52:   try {\n53:     emitter.emit({ type: \"loop.description\", description });\n54: \n55:     if (flags.dryRun) {\n56:       let iteration = 0;\n57:       while (iteration < maxIterations) {\n58:         const next = await callbacks.nextIteration(config, iteration + 1);\n59:         if (!next) break;\n60:         iteration++;\n61:         const modelStr = `${next.model.providerID}/${next.model.modelID}`;\n62:         emitter.emit({\n63:           type: \"loop.dry_run_iteration\",\n64:           iteration,\n65:           label: next.iterationLabel,\n66:           model: modelStr,\n67:         });\n68:       }\n69:       emitter.emit({\n70:         type: \"loop.dry_run_complete\",\n71:         iterations: iteration,\n72:         maxIterations,\n73:       });\n74:       runTracker.finalize(\"completed\");\n75:       finalized = true;\n76:       return { completed: 0, failed: 0, skipped: 0, totalTime: 0, maxIterations, iterations: [] };\n77:     }\n78: \n79:     if (flags.attach) {\n80:       server = await connectToServer(flags.attach);\n81:       emitter.emit({ type: \"server.attached\", url: server.url });\n82:     } else {\n83:       server = await startServer();\n84:       emitter.emit({ type: \"server.started\", url: server.url });\n85:       emitter.emit({ type: \"server.attach_hint\", url: server.url });\n86:     }\n87: \n88:     let iteration = 0;\n89:     let completed = 0;\n90:     let failed = 0;\n91:     let skipped = 0;\n92:     const iterations: IterationResult[] = [];\n93:     const retryCount = new Map<string, number>();\n94:     const startTime = Date.now();\n95: \n96:     while (iteration < maxIterations) {\n97:       const next = await callbacks.nextIteration(config, iteration + 1);\n98:       if (!next) break;\n99: \n100:       iteration++;\n101:       const modelStr = `${next.model.providerID}/${next.model.modelID}`;\n102:       emitter.emit({\n103:         type: \"iteration.started\",\n104:         iteration,\n105:         label: next.iterationLabel,\n106:         model: modelStr,\n107:       });\n108: \n109:       const iterStartTime = Date.now();\n110: \n111:       try {\n112:         const sessionId = await createSession(server.client, next.sessionTitle);\n113:         emitter.emit({ type: \"iteration.session_created\", sessionId });\n114: \n115:         const timeoutMs = config.engine.timeout_minutes * 60 * 1000;\n116:         const inactivityTimeoutMs = config.engine.inactivity_timeout_seconds * 1000;\n117:         const promptResult = await withTimeout(\n118:           runPrompt(server.client, sessionId, next.prompt, next.model, next.systemPrompt, server.url, inactivityTimeoutMs),\n119:           timeoutMs,\n120:           `Iteration timed out after ${config.engine.timeout_minutes}m`,\n121:         );\n122:         const result = promptResult.completion;\n123:         const iterDuration = Date.now() - iterStartTime;\n124: \n125:         const iterResult: IterationResult = {\n126:           iteration,\n127:           beadId: next.beadId || `iter-${iteration}`,\n128:           beadTitle: next.iterationLabel,\n129:           status: result.status,\n130:           reason: result.reason,\n131:           model: modelStr,\n132:           duration: iterDuration,\n133:           cost: promptResult.cost,\n134:           tokens: promptResult.tokens,\n135:           filesChanged: promptResult.filesChanged,\n136:         };\n137: \n138:         const transcriptPath = runTracker.writeIterationTranscript(\n139:           iteration,\n140:           next.iterationLabel,\n141:           promptResult.rawOutput,\n142:           promptResult.displayOutput,\n143:         );\n144:         if (transcriptPath) {\n145:           iterResult.transcriptPath = transcriptPath;\n146:         }\n147: \n148:         iterations.push(iterResult);\n149:         appendProgress(projectDir, iteration, iterResult);\n150: \n151:         const shouldContinue = await callbacks.handleResult(result, iteration);\n152: \n153:         if (result.status === \"complete\" || result.status === \"phase_done\") {\n154:           completed++;\n155:           emitter.emit({\n156:             type: \"iteration.completed\",\n157:             iteration,\n158:             label: next.iterationLabel,\n159:             status: result.status,\n160:             reason: result.reason,\n161:           });\n162:         } else if (result.status === \"blocked\") {\n163:           skipped++;\n164:           emitter.emit({\n165:             type: \"iteration.blocked\",\n166:             iteration,\n167:             label: next.iterationLabel,\n168:             reason: result.reason,\n169:           });\n170:         } else {\n171:           const key = next.iterationLabel;\n172:           const currentRetries = retryCount.get(key) || 0;\n173:           if (config.engine.strategy === \"retry\" && currentRetries < config.engine.max_retries) {\n174:             retryCount.set(key, currentRetries + 1);\n175:             emitter.emit({\n176:               type: \"iteration.retrying\",\n177:               iteration,\n178:               label: next.iterationLabel,\n179:               status: result.status,\n180:               attempt: currentRetries + 1,\n181:               maxRetries: config.engine.max_retries,\n182:             });\n183:             iteration--;\n184:           } else if (config.engine.strategy === \"abort\") {\n185:             failed++;\n186:             emitter.emit({\n187:               type: \"iteration.failed\",\n188:               iteration,\n189:               label: next.iterationLabel,\n190:               status: result.status,\n191:               action: \"aborting\",\n192:             });\n193:             break;\n194:           } else {\n195:             failed++;\n196:             emitter.emit({\n197:               type: \"iteration.failed\",\n198:               iteration,\n199:               label: next.iterationLabel,\n200:               status: result.status,\n201:               action: \"skipping\",\n202:             });\n203:           }\n204:         }\n205: \n206:         if (!shouldContinue) break;\n207: \n208:       } catch (err) {\n209:         const iterDuration = Date.now() - iterStartTime;\n210:         const iterResult: IterationResult = {\n211:           iteration,\n212:           beadId: next.beadId || `iter-${iteration}`,\n213:           beadTitle: next.iterationLabel,\n214:           status: \"error\",\n215:           reason: (err as Error).message,\n216:           model: modelStr,\n217:           duration: iterDuration,\n218:         };\n219:         iterations.push(iterResult);\n220:         appendProgress(projectDir, iteration, iterResult);\n221:         failed++;\n222:         emitter.emit({\n223:           type: \"iteration.error\",\n224:           iteration,\n225:           label: next.iterationLabel,\n226:           error: (err as Error).message,\n227:         });\n228:         if (config.engine.strategy === \"abort\") break;\n229:       }\n230: \n231:       if (config.engine.iteration_delay_ms > 0) {\n232:         await new Promise((r) => setTimeout(r, config.engine.iteration_delay_ms));\n233:       }\n234:     }\n235:     const totalTime = Date.now() - startTime;\n236:     emitter.emit({\n237:       type: \"loop.completed\",\n238:       completed,\n239:       failed,\n240:       skipped,\n241:       totalTimeMs: totalTime,\n242:     });\n243: \n244:     runTracker.finalize(failed > 0 ? \"failed\" : \"completed\");\n245:     finalized = true;\n246: \n247:     return { completed, failed, skipped, totalTime, maxIterations, iterations };\n248:   } finally {\n249:     detachTracker();\n250:     if (!finalized) {\n251:       runTracker.finalize(\"failed\");\n252:     }\n253:     cleanup();\n254:   }\n255: }\n\n(End of file - total 255 lines)\n</content>","title":"src/engine.ts","metadata":{"preview":"import { loadConfig } from \"./config.js\";\nimport { startServer, connectToServer, createSession, runPrompt, type ServerHandle } from \"./opencode.js\";\nimport { appendProgress } from \"./progress.js\";\nimport type { LoopConfig, LoopResult, IterationResult, CompletionResult, PhaseFlags } from \"./types.js\";\nimport { EngineEventEmitter, attachDefaultConsoleRenderer, type EngineEventListener } from \"./events.js\";\nimport { startRunTracker } from \"./run-state.js\";\nimport { withTimeout } from \"./timeout.js\";\n\nexport interface PhaseIteration {\n  prompt: string;\n  model: { providerID: string; modelID: string };\n  sessionTitle: string;\n  iterationLabel: string;\n  beadId?: string;\n  systemPrompt?: string;\n}\n\nexport interface PhaseCallbacks {\n  setup(config: LoopConfig, dryRun: boolean): Promise<{ maxIterations: number; description: string }>;\n  nextIteration(config: LoopConfig, iteration: number): Promise<PhaseIteration | null>;","truncated":false,"loaded":[]},"time":{"start":1772181447819,"end":1772181447825}}}}
{"type":"tool_use","timestamp":1772181448225,"sessionID":"ses_361c37f15ffeuVWV0XN4ZPvLel","part":{"id":"prt_c9e3ee48e0017YFwA7XZk7Mjp9","sessionID":"ses_361c37f15ffeuVWV0XN4ZPvLel","messageID":"msg_c9e3edad0001f7NP8UkAoywKhP","type":"tool","callID":"toolu_01CuZhcN8deN8Z6g6UZhJ667","tool":"read","state":{"status":"completed","input":{"filePath":"/Users/mat/dev/farsight/agent-framework/src/opencode.ts"},"output":"<path>/Users/mat/dev/farsight/agent-framework/src/opencode.ts</path>\n<type>file</type>\n<content>1: import { createOpencode, createOpencodeClient, type OpencodeClient, type Part } from \"@opencode-ai/sdk\";\n2: import { createOpencodeClient as createV2Client } from \"@opencode-ai/sdk/v2\";\n3: import { existsSync, lstatSync, readdirSync, unlinkSync, readlinkSync } from \"fs\";\n4: import { join } from \"path\";\n5: import { homedir } from \"os\";\n6: import type { CompletionResult } from \"./types.js\";\n7: import { StreamCapture } from \"./output-parser.js\";\n8: \n9: export type { OpencodeClient };\n10: \n11: export interface PromptResult {\n12:   completion: CompletionResult;\n13:   cost: number;\n14:   tokens: { input: number; output: number; reasoning: number };\n15:   filesChanged: string[];\n16:   rawOutput: string;\n17:   displayOutput: string;\n18: }\n19: \n20: export interface ServerHandle {\n21:   client: OpencodeClient;\n22:   url: string;\n23:   close: () => void;\n24: }\n25: \n26: /**\n27:  * Scan OpenCode's global config directories for broken symlinks.\n28:  * OpenCode crashes on startup if it encounters broken plugin or command symlinks.\n29:  * Returns a list of broken symlinks that were found (and optionally removed).\n30:  */\n31: export function checkBrokenSymlinks(opts: { fix?: boolean } = {}): string[] {\n32:   const configDir = join(homedir(), \".config\", \"opencode\");\n33:   const dirsToCheck = [\"plugins\", \"commands\"];\n34:   const broken: string[] = [];\n35: \n36:   for (const sub of dirsToCheck) {\n37:     const dir = join(configDir, sub);\n38:     if (!existsSync(dir)) continue;\n39: \n40:     let entries: string[];\n41:     try {\n42:       entries = readdirSync(dir);\n43:     } catch {\n44:       continue;\n45:     }\n46: \n47:     for (const entry of entries) {\n48:       const fullPath = join(dir, entry);\n49:       try {\n50:         const stat = lstatSync(fullPath);\n51:         if (stat.isSymbolicLink()) {\n52:           // Check if the symlink target exists\n53:           const target = readlinkSync(fullPath);\n54:           if (!existsSync(fullPath)) {\n55:             broken.push(fullPath);\n56:             if (opts.fix) {\n57:               unlinkSync(fullPath);\n58:               console.log(`Removed broken symlink: ${fullPath} -> ${target}`);\n59:             }\n60:           }\n61:         }\n62:       } catch {\n63:         // Can't stat — treat as broken\n64:         broken.push(fullPath);\n65:       }\n66:     }\n67:   }\n68: \n69:   return broken;\n70: }\n71: \n72: // Start an ephemeral OpenCode server and return a client + handle\n73: export async function startServer(): Promise<ServerHandle> {\n74:   // Preflight: broken symlinks in ~/.config/opencode/ crash the server\n75:   const broken = checkBrokenSymlinks({ fix: true });\n76:   if (broken.length > 0) {\n77:     console.log(`Fixed ${broken.length} broken symlink(s) in ~/.config/opencode/`);\n78:   }\n79: \n80:   const { client, server } = await createOpencode({ port: 0 });\n81: \n82:   // Verify server is ready\n83:   try {\n84:     await client.session.list();\n85:   } catch (err) {\n86:     server.close();\n87:     throw new Error(`OpenCode server started but not responding: ${(err as Error).message}`);\n88:   }\n89: \n90:   return {\n91:     client,\n92:     url: server.url,\n93:     close: () => server.close(),\n94:   };\n95: }\n96: \n97: // Connect to an existing OpenCode server (for --attach mode)\n98: export async function connectToServer(url: string): Promise<ServerHandle> {\n99:   const client = createOpencodeClient({ baseUrl: url });\n100: \n101:   // Verify server is reachable by listing sessions\n102:   try {\n103:     await client.session.list();\n104:   } catch (err) {\n105:     throw new Error(\n106:       `Cannot connect to OpenCode server at ${url}: ${(err as Error).message}`,\n107:     );\n108:   }\n109: \n110:   return {\n111:     client,\n112:     url,\n113:     close: () => {}, // External server — don't close it\n114:   };\n115: }\n116: \n117: // Create a new session for a bead\n118: export async function createSession(\n119:   client: OpencodeClient,\n120:   title: string,\n121: ): Promise<string> {\n122:   const response = await client.session.create({ body: { title } });\n123:   if (!response.data) {\n124:     throw new Error(\"Failed to create session\");\n125:   }\n126:   return response.data.id;\n127: }\n128: \n129: // Send a prompt and stream output to the terminal in real-time.\n130: // Uses promptAsync() to start non-blocking, then subscribes to SSE events\n131: // to display text deltas as they arrive. Returns when session goes idle.\n132: export async function runPrompt(\n133:   client: OpencodeClient,\n134:   sessionId: string,\n135:   prompt: string,\n136:   model: { providerID: string; modelID: string },\n137:   systemPrompt?: string,\n138:   serverUrl?: string,\n139:   inactivityTimeoutMs: number = 180000,\n140: ): Promise<PromptResult> {\n141:   // Use v2 client for promptAsync + event streaming\n142:   const v2 = createV2Client({ baseUrl: serverUrl || \"http://127.0.0.1:4096\" });\n143: \n144:   // Subscribe to events BEFORE sending prompt so we don't miss anything\n145:   const { stream } = await v2.event.subscribe();\n146: \n147:   // Start the prompt asynchronously\n148:   await v2.session.promptAsync({\n149:     sessionID: sessionId,\n150:     model,\n151:     parts: [{ type: \"text\" as const, text: prompt }],\n152:     ...(systemPrompt && { system: systemPrompt }),\n153:   });\n154: \n155:   // Stream events until session goes idle, with inactivity watchdog + heartbeat.\n156:   const capture = new StreamCapture();\n157:   const iterator = stream[Symbol.asyncIterator]();\n158:   const pollMs = 10_000;\n159:   const heartbeatMs = 30_000;\n160:   let lastEventAt = Date.now();\n161:   let lastHeartbeatAt = Date.now();\n162: \n163:   try {\n164:     while (true) {\n165:       let tickTimer: ReturnType<typeof setTimeout> | undefined;\n166:       const nextResult = await Promise.race([\n167:         iterator.next().then((result) => ({ type: \"event\" as const, result })),\n168:         new Promise<{ type: \"tick\" }>((resolve) =>\n169:           { tickTimer = setTimeout(() => resolve({ type: \"tick\" }), pollMs); }\n170:         ),\n171:       ]);\n172: \n173:       if (tickTimer) clearTimeout(tickTimer);\n174: \n175:       if (nextResult.type === \"tick\") {\n176:         const idleForMs = Date.now() - lastEventAt;\n177:         if (idleForMs >= inactivityTimeoutMs) {\n178:           throw new Error(`Session inactive for ${Math.round(inactivityTimeoutMs / 1000)}s`);\n179:         }\n180: \n181:         if (Date.now() - lastHeartbeatAt >= heartbeatMs) {\n182:           const idleSec = Math.round(idleForMs / 1000);\n183:           process.stdout.write(`\\n[heartbeat] session active, waiting for events (${idleSec}s idle)\\n`);\n184:           lastHeartbeatAt = Date.now();\n185:         }\n186:         continue;\n187:       }\n188: \n189:       if (nextResult.result.done) break;\n190: \n191:       const ev = nextResult.result.value as Record<string, unknown>;\n192:       const eventType = ev.type as string;\n193:       lastEventAt = Date.now();\n194: \n195:       if (eventType) {\n196:         capture.addRawLine(JSON.stringify(ev));\n197:       }\n198: \n199:       // Debug: log event details\n200:       if (process.env.SUPER_RALPH_DEBUG) {\n201:         if (eventType === \"message.part.delta\" || eventType === \"message.part.updated\") {\n202:           const props = ev.properties as Record<string, unknown>;\n203:           process.stderr.write(`[debug] ${eventType}: ${JSON.stringify(props).slice(0, 300)}\\n`);\n204:         } else if (eventType === \"session.idle\" || eventType === \"session.error\") {\n205:           process.stderr.write(`[debug] ${eventType}: ${JSON.stringify(ev.properties).slice(0, 300)}\\n`);\n206:         }\n207:       }\n208: \n209:       if (eventType === \"message.part.delta\") {\n210:         // Real-time text streaming — print deltas as they arrive\n211:         const props = ev.properties as Record<string, unknown>;\n212:         if ((props.sessionID as string) !== sessionId) continue;\n213:         if ((props.field as string) === \"text\" && props.delta) {\n214:           const text = props.delta as string;\n215:           capture.addDisplayText(text);\n216:           process.stdout.write(text);\n217:         }\n218:       } else if (eventType === \"message.part.updated\") {\n219:         const props = ev.properties as Record<string, unknown>;\n220:         const part = props.part as Record<string, unknown> | undefined;\n221:         const eventSessionId = part?.sessionID as string || props.sessionID as string;\n222:         if (eventSessionId !== sessionId || !part) continue;\n223: \n224:         const partType = part.type as string;\n225:         if (partType === \"tool\") {\n226:           const toolName = part.tool as string;\n227:           const state = part.state as Record<string, unknown> | undefined;\n228:           const status = state?.status as string | undefined;\n229:           const error = state?.error as string | undefined;\n230: \n231:           if (status) {\n232:             const toolText = capture.toolStatusText(toolName, status, error);\n233:             if (toolText) {\n234:               capture.addDisplayText(toolText);\n235:               process.stdout.write(toolText);\n236:             }\n237:           }\n238:         }\n239:       } else if (eventType === \"session.idle\") {\n240:         const props = ev.properties as Record<string, unknown>;\n241:         if ((props.sessionID as string) === sessionId) {\n242:           capture.addDisplayText(\"\\n\");\n243:           process.stdout.write(\"\\n\");\n244:           break;\n245:         }\n246:       } else if (eventType === \"session.error\") {\n247:         const props = ev.properties as Record<string, unknown>;\n248:         if ((props.sessionID as string) === sessionId) {\n249:           const error = props.error as Record<string, unknown> | string | undefined;\n250:           let errorMsg = \"unknown error\";\n251:           if (typeof error === \"string\") {\n252:             errorMsg = error;\n253:           } else if (error && typeof error === \"object\") {\n254:             const name = error.name as string || \"Error\";\n255:             const data = error.data as Record<string, unknown> | undefined;\n256:             const message = data?.message as string || JSON.stringify(error);\n257:             errorMsg = `${name}: ${message}`;\n258:           }\n259:           const errorText = `\\n[session error: ${errorMsg}]\\n`;\n260:           capture.addDisplayText(errorText);\n261:           process.stdout.write(errorText);\n262:           break;\n263:         }\n264:       }\n265:     }\n266:   } catch (err) {\n267:     if ((err as Error).message.includes(\"Session inactive for\")) {\n268:       // Best-effort abort to avoid zombie sessions after inactivity timeout.\n269:       try {\n270:         await v2.session.abort({ sessionID: sessionId });\n271:       } catch {\n272:         // ignore abort failures\n273:       }\n274:     }\n275:     throw err;\n276:   } finally {\n277:     // Explicitly close the event stream to avoid lingering SSE connections\n278:     // that can delay process exit by minutes.\n279:     if (typeof stream.return === \"function\") {\n280:       await stream.return(undefined);\n281:     }\n282:   }\n283: \n284:   // Session complete — gather results from v1 client (which has the right types)\n285:   let completion: CompletionResult = {\n286:     status: \"stalled\",\n287:     reason: \"Session completed without calling task_complete\",\n288:   };\n289: \n290:   const allMsgs = await client.session.messages({ path: { id: sessionId } });\n291:   let totalCost = 0;\n292:   let totalInput = 0;\n293:   let totalOutput = 0;\n294:   let totalReasoning = 0;\n295: \n296:   if (allMsgs.data) {\n297:     for (const msg of allMsgs.data) {\n298:       // Check for task_complete\n299:       const found = extractCompletion(msg.parts);\n300:       if (found.status !== \"stalled\") {\n301:         completion = found;\n302:       }\n303: \n304:       // Sum cost/tokens\n305:       if (msg.info.role === \"assistant\") {\n306:         totalCost += (msg.info as Record<string, unknown>).cost as number || 0;\n307:         const tok = (msg.info as Record<string, unknown>).tokens as Record<string, number> | undefined;\n308:         if (tok) {\n309:           totalInput += tok.input || 0;\n310:           totalOutput += tok.output || 0;\n311:           totalReasoning += tok.reasoning || 0;\n312:         }\n313:       }\n314:     }\n315:   }\n316: \n317:   // Get files changed from session diff\n318:   let filesChanged: string[] = [];\n319:   try {\n320:     const diffResponse = await client.session.diff({\n321:       path: { id: sessionId },\n322:     });\n323:     if (diffResponse.data) {\n324:       filesChanged = diffResponse.data.map((d) => d.file);\n325:     }\n326:   } catch {\n327:     // Diffs might not be available\n328:   }\n329: \n330:   return {\n331:     completion,\n332:     cost: totalCost,\n333:     tokens: { input: totalInput, output: totalOutput, reasoning: totalReasoning },\n334:     filesChanged,\n335:     rawOutput: capture.getRawOutput(),\n336:     displayOutput: capture.getDisplayOutput(),\n337:   };\n338: }\n339: \n340: // Extract completion status from message parts\n341: function extractCompletion(parts: Part[]): CompletionResult {\n342:   for (const part of parts) {\n343:     if (\n344:       part.type === \"tool\" &&\n345:       part.tool === \"task_complete\" &&\n346:       part.state.status === \"completed\"\n347:     ) {\n348:       const input = part.state.input as Record<string, unknown>;\n349:       return {\n350:         status: (input.status as CompletionResult[\"status\"]) || \"complete\",\n351:         reason: input.reason as string | undefined,\n352:       };\n353:     }\n354:   }\n355: \n356:   // No task_complete found — session completed without calling it\n357:   return {\n358:     status: \"stalled\",\n359:     reason: \"Session completed without calling task_complete\",\n360:   };\n361: }\n362: \n363: // Show a toast notification in the OpenCode TUI\n364: export async function showToast(\n365:   client: OpencodeClient,\n366:   message: string,\n367:   variant: \"info\" | \"success\" | \"warning\" | \"error\",\n368: ): Promise<void> {\n369:   try {\n370:     await client.tui.showToast({\n371:       body: { message, variant, duration: 5000 },\n372:     });\n373:   } catch {\n374:     // If toast fails, just log\n375:     const icon =\n376:       variant === \"success\"\n377:         ? \"\\u2713\"\n378:         : variant === \"error\"\n379:           ? \"\\u2717\"\n380:           : variant === \"warning\"\n381:             ? \"\\u26A0\"\n382:             : \"\\u2139\";\n383:     console.log(`[${icon}] ${message}`);\n384:   }\n385: }\n386: \n387: // Abort a running session\n388: export async function abortSession(\n389:   client: OpencodeClient,\n390:   sessionId: string,\n391: ): Promise<void> {\n392:   await client.session.abort({ path: { id: sessionId } });\n393: }\n\n(End of file - total 393 lines)\n</content>","title":"src/opencode.ts","metadata":{"preview":"import { createOpencode, createOpencodeClient, type OpencodeClient, type Part } from \"@opencode-ai/sdk\";\nimport { createOpencodeClient as createV2Client } from \"@opencode-ai/sdk/v2\";\nimport { existsSync, lstatSync, readdirSync, unlinkSync, readlinkSync } from \"fs\";\nimport { join } from \"path\";\nimport { homedir } from \"os\";\nimport type { CompletionResult } from \"./types.js\";\nimport { StreamCapture } from \"./output-parser.js\";\n\nexport type { OpencodeClient };\n\nexport interface PromptResult {\n  completion: CompletionResult;\n  cost: number;\n  tokens: { input: number; output: number; reasoning: number };\n  filesChanged: string[];\n  rawOutput: string;\n  displayOutput: string;\n}\n\nexport interface ServerHandle {","truncated":false,"loaded":[]},"time":{"start":1772181448222,"end":1772181448224}}}}
